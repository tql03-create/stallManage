/* 页面基础样式 */
page {
  background-color: #f8f8f8;
}

/* 主容器样式 */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f8f8f8;
  box-sizing: border-box;
}

/* 用户信息样式 */
.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  background: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.1);
}

.user-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

/* 现有样式保持不变 */

/* 注销按钮样式 */
.logout-btn {
  margin-left: auto;
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.logout-btn:active {
  opacity: 0.7;
  background-color: #e0e0e0;
}

.logout-text {
  font-size: 24rpx;
  color: #ff4d4f;
}

/* 摊位信息容器 */
.stall-container {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  margin-bottom: 30rpx;
  transition: box-shadow 0.3s ease;
}

.stall-container:hover {
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

/* 摊位头部信息 */
.stall-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.stall-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.stall-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  transition: all 0.3s ease;
}

.stall-status.open {
  background: #e8f5e9;
  color: #4caf50;
}

.stall-status.closed {
  background: #f5f5f5;
  color: #999;
}

/* 摊位图片样式 */
.stall-image-wrapper {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.stall-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.stall-image:hover {
  transform: scale(1.02);
}

/* 摊位描述样式 */
.stall-desc {
  margin-top: 30rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.desc-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.desc-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

/* 操作按钮样式 */
.action-buttons {
  margin-top: 60rpx;
  display: flex;
  gap: 20rpx;
}

.edit-btn, .toggle-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.edit-btn {
  background: #f5f5f5;
  color: #333;
}

.edit-btn:active {
  background: #e0e0e0;
  transform: translateY(2rpx);
}

.toggle-btn {
  background: #ff4d4f;
  color: #fff;
}

.toggle-btn.open {
  background: #52c41a;
}

.toggle-btn:active {
  opacity: 0.9;
  transform: translateY(2rpx);
}

/* 加载状态样式 */
.loading {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  z-index: 999;
}