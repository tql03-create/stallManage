.vendor-container {
    padding: 20rpx;
}

/* 用户信息样式 */
.user-info {
    display: flex;
    align-items: center;
    margin-bottom: 40rpx;
}

.avatar {
    width: 100rpx;
    height: 100rpx;
    border-radius: 50%;
    margin-right: 20rpx;
}

.nickname {
    font-size: 32rpx;
    font-weight: bold;
}

/* 摊主信息编辑区域样式 */
.vendor-edit {
    margin-top: 20rpx;
}

.save-button {
    margin-top: 40rpx;
    display: flex;
    justify-content: center;
}