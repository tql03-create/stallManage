/* 页面基础样式 */
page {
    background-color: #f8f8f8;
}

/* 主容器样式 */
.container {
    padding: 30rpx;
    background-color: #f8f8f8;
    min-height: 100vh;
    box-sizing: border-box;
}
  
  /* 标题和提示文本样式 */
.title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
    text-align: center;
    margin-bottom: 20rpx;
}

.tip {
    font-size: 28rpx;
    color: #666;
    text-align: center;
    margin-bottom: 30rpx;
}
  
  /* 邀请码输入框样式 */
.invite-input {
    width: 100%;
    height: 88rpx;
    border: 1rpx solid #ddd;
    border-radius: 8rpx;
    padding: 0 24rpx;
    font-size: 28rpx;
    margin-bottom: 30rpx;
    box-sizing: border-box;
    background: #fff;
    transition: border-color 0.3s ease;
}

.invite-input:focus {
    border-color: #07c160;
}

/* 验证按钮样式 */
.verify-btn {
    width: 100%;
    height: 88rpx;
    background-color: #07c160;
    color: #fff;
    font-size: 32rpx;
    border-radius: 44rpx;
    margin-bottom: 20rpx;
    transition: opacity 0.3s ease;
}

.verify-btn[disabled] {
    opacity: 0.6;
}
  
  /* 用户信息表单样式 */
.user-info-form {
    background: #fff;
    border-radius: 12rpx;
    padding: 30rpx;
    margin-top: 20rpx;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
    transition: box-shadow 0.3s ease;
}

.user-info-form:hover {
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}
  
  
  /* 头像选择器样式 */
.avatar-wrapper {
    width: 180rpx;
    height: 180rpx;
    padding: 0;
    margin: 0 auto;
    display: block;
    border-radius: 10rpx;
    overflow: hidden;
    background: none;
    border: none;
    transition: transform 0.3s ease;
}

.avatar-wrapper:active {
    transform: scale(0.95);
}

.avatar {
    width: 100%;
    height: 100%;
    display: block;
    
}
  
  .avatar-tip {
    display: block;
    text-align: center;
    font-size: 28rpx;
    color: #666;
    margin: 20rpx 0 40rpx;
  }
  
  /* 昵称输入区域样式 */
.nickname-wrapper {
    margin-top: 30rpx;
}

.nickname-label {
    display: block;
    font-size: 28rpx;
    color: #333;
    margin-bottom: 16rpx;
}

.nickname-input {
    width: 100%;
    height: 88rpx;
    background: #f5f5f5;
    border-radius: 8rpx;
    padding: 0 24rpx;
    font-size: 28rpx;
    box-sizing: border-box;
    transition: background-color 0.3s ease;
}

.nickname-input:focus {
    background-color: #fff;
    box-shadow: inset 0 0 0 1px #07c160;
}
  
  /* 注册按钮样式 */
.login-btn {
    width: 100%;
    height: 88rpx;
    background: #07c160;
    color: #fff;
    font-size: 32rpx;
    border-radius: 44rpx;
    margin-top: 60rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
}

.login-btn:active {
    transform: translateY(2rpx);
    opacity: 0.9;
}

.login-btn[disabled] {
    opacity: 0.6;
    background: #999;
}
  
  /* 按钮点击态 */
  .verify-btn:active,
  .login-btn:active {
    opacity: 0.8;
  }