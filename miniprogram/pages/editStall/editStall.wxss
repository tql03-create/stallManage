.container {
    padding: 20px;
  }
  .form-item {
    margin-bottom: 20px;
  }
  .label {
    display: block;
    margin-bottom: 5px;
    color: #333;
  }
  .input, .textarea {
    width: 100%;
    padding: 10px;
    border: 1px solid #ccc;
    border-radius: 5px;
  }
  .textarea {
    height: 100px;
  }
  .upload-btn {
    padding: 10px;
    background-color: #1aad19;
    color: #fff;
    text-align: center;
    border-radius: 5px;
  }
  .stall-image {
    width: 100%;
    height: 200px;
    margin-top: 10px;
    border: 1px solid #ccc;
  }
  .save-btn {
    width: 100%;
    padding: 10px;
    background-color: #1aad19;
    color: #fff;
    text-align: center;
    border-radius: 5px;
  }
  