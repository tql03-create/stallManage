<view class="container">
  <!-- 用户信息展示 -->
  <view class="user-info">
    <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
    <text class="user-name">{{userInfo.nickName}}</text>
  </view>

  <!-- 摊位信息表单 -->
  <view class="form-container">
    <view class="form-item">
      <text class="label">摊位名称</text>
      <input class="input" placeholder="给你的摊位起个名字吧" bindinput="handleStallNameInput" value="{{stallName}}" aria-label="摊位名称输入框" />
    </view>

    <view class="form-item">
      <text class="label">摊位描述</text>
      <textarea class="textarea" placeholder="介绍一下你的摊位特色" bindinput="handleStallDescInput" value="{{stallDesc}}" aria-label="摊位描述输入框"></textarea>
    </view>

    <view class="form-item">
      <text class="label">摊位图片</text>
      <view class="image-uploader" bindtap="handleImageUpload" role="button" aria-label="上传摊位图片">
        <image wx:if="{{stallImage}}" class="stall-image" src="{{stallImage}}" mode="aspectFill" />
        <view wx:else class="upload-placeholder">
          <text class="iconfont icon-add"></text>
          <text class="upload-text">上传图片</text>
        </view>
      </view>
    </view>
  </view>

  <button class="save-btn" bindtap="handleSaveStall" aria-label="保存摊位信息">保存摊位</button>
</view>