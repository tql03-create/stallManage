/* 页面容器 */
.container {
    min-height: 100vh;
    background: #f8f8f8;
    padding-bottom: 40rpx;
    box-sizing: border-box;
  }
  
  /* 用户信息样式 */
  .user-info {
    background: #fff;
    padding: 40rpx 30rpx;
    display: flex;
    align-items: center;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  }
  
  .user-avatar {
    width: 100rpx;
    height: 100rpx;
    border-radius: 50%;
    margin-right: 24rpx;
  }
  
  .user-name {
    font-size: 32rpx;
    color: #333;
    font-weight: 500;
  }
  /* 现有样式保持不变 */

/* 注销按钮样式 */
.logout-btn {
  margin-left: auto;
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.logout-btn:active {
  opacity: 0.7;
  background-color: #e0e0e0;
}

.logout-text {
  font-size: 24rpx;
  color: #ff4d4f;
}
  /* 表单容器 */
  .form-container {
    background: #fff;
    padding: 30rpx;
    border-radius: 16rpx;
    margin: 0 20rpx;
    box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  }
  
  .form-item {
    margin-bottom: 40rpx;
  }
  
  .label {
    display: block;
    font-size: 28rpx;
    color: #333;
    margin-bottom: 16rpx;
    font-weight: 500;
  }
  
  .input {
    width: 100%;
    height: 88rpx;
    background: #f5f7fa;
    border-radius: 8rpx;
    padding: 0 24rpx;
    font-size: 28rpx;
    box-sizing: border-box;
  }
  
  .textarea {
    width: 100%;
    height: 200rpx;
    background: #f5f7fa;
    border-radius: 8rpx;
    padding: 20rpx 24rpx;
    font-size: 28rpx;
    box-sizing: border-box;
  }
  
  /* 图片上传区域 */
  .image-uploader {
    width: 240rpx;
    height: 240rpx;
    background: #f5f7fa;
    border-radius: 8rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  
  .upload-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    color: #999;
  }
  
  .icon-add {
    font-size: 48rpx;
    margin-bottom: 12rpx;
  }
  
  .upload-text {
    font-size: 24rpx;
  }
  
  .stall-image {
    width: 100%;
    height: 100%;
    border-radius: 8rpx;
  }
  
  /* 保存按钮 */
  .save-btn {
    width: 90%;
    height: 88rpx;
    background: #07c160;
    color: #fff;
    font-size: 32rpx;
    border-radius: 44rpx;
    margin: 60rpx auto 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 500;
  }
  
  .save-btn:active {
    opacity: 0.9;
  }

  /* 文本内容样式 */
.text-content {
    font-size: 28rpx;
    color: #333;
    line-height: 1.6;
    padding: 20rpx 0;
  }
  
/* 编辑按钮样式 */
.edit-btn {
    width: 90%;
    height: 88rpx;
    background: #f0f0f0;
    color: #333;
    font-size: 32rpx;
    border-radius: 44rpx;
    margin: 60rpx auto 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 500;
    transition: opacity 0.2s ease;
  }

.edit-btn:active {
    opacity: 0.9;
  }