/** 页面整体容器 **/
page{
    background-color: #f8f8f8;
}
.container {
    padding: 20rpx;
    background-color: #f8f8f8;
    position: relative;
    /* 为了放置右下角按钮 */
}

/** 顶部搜索栏 **/
.header {
    display: flex;
    align-items: center;
    margin-bottom: 20rpx;
}

.search-bar {
    flex: 1;
    display: flex;
    align-items: center;
    background-color: #ffffff;
    border-radius: 10rpx;
    padding: 10rpx;
    margin-right: 20rpx;
}

.search-icon {
    width: 40rpx;
    height: 40rpx;
    margin-right: 10rpx;
}

.search-input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 26rpx;
}

/** 右侧头像按钮 **/
.owner-avatar {
    width: 70rpx;
    height: 70rpx;
    border-radius: 50%;
    overflow: hidden;
}

.avatar-icon {
    width: 100%;
    height: 100%;
}
.no-data {
    text-align: center;
    color: #999;
    padding: 30rpx;
    font-size: 28rpx;
}
/** 出摊与否状态模块 **/
.stall-info {
    padding: 20rpx;
    background-color: #fff;
    border-radius: 10rpx;
    margin-bottom: 20rpx;
    text-align: center;
  }
  .stall-name {
    font-size: 28rpx;
    font-weight: bold;
    margin-bottom: 10rpx;
  }
  .stall-status {
    font-size: 24rpx;
    color: #f44;
  }

/** 轮播图容器 **/
.swiper-container {
    width: 100%;
    height: 300rpx;
    margin-bottom: 30rpx;
    border-radius: 10rpx;
    overflow: hidden;
}

.swiper-image {
    width: 100%;
    height: 300rpx;
}

/** 标题 **/
.section-title {
    font-size: 32rpx;
    font-weight: bold;
    margin-bottom: 20rpx;
    color: #333;
}



/** 摊位卡片 **/
.stall-card {
    display: flex;
    /* align-items: center; */
    background-color: #ffffff;
    border-radius: 10rpx;
    margin-bottom: 20rpx;
    padding: 20rpx;
    box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}

/** 打烊时整张卡片半透明显示 **/
.stall-card.closed {
    opacity: 0.5;
}

/** 头像区域 **/
.avatar-container {
    position: relative;
    margin-right: 5rpx;
}

.avatar {
    width: 300rpx;
    height: 300rpx;
    /* border-radius: 50%; */
    background-color: #eee;
}

/** 休息中文案 **/
.resting {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: #f44;
    font-size: 24rpx;
    font-weight: bold;
}

/** 摊位文字信息 **/
.stall-info {
    flex: 1;
}

.stall-name {
    font-size: 28rpx;
    font-weight: bold;
    margin-bottom: 8rpx;
    color: #000;
}

.stall-desc {
    font-size: 24rpx;
    color: #666;
}

/** 右下角 出摊/收摊 切换按钮 **/
wx-button.toggle-btn {
    position: fixed;
    right: 20rpx;
    bottom: 40rpx;
    width: 180rpx;
    height: 60rpx;
    background-color: #ff9900;
    color: #fff;
    border-radius: 30rpx;
    font-size: 24rpx;
    box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.2);
    display: flex;
    /* 使用 Flexbox 布局 */
    justify-content: center;
    /* 水平居中 */
    align-items: center;
    /* 垂直居中 */
}