/* 页面基础样式 */
page {
    background-color: #f8f8f8;
}

/* 主容器样式 */
.container {
    padding: 20rpx;
    background-color: #f8f8f8;
    position: relative;
    min-height: 100vh;
    box-sizing: border-box;
}

/** 顶部搜索栏 **/
.header {
    display: flex;
    align-items: center;
    margin-bottom: 20rpx;
}

.search-bar {
    flex: 1;
    display: flex;
    align-items: center;
    background-color: #ffffff;
    border-radius: 10rpx;
    padding: 10rpx;
    margin-right: 20rpx;
}

.search-icon {
    width: 40rpx;
    height: 40rpx;
    margin-right: 10rpx;
}

.search-input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 26rpx;
}

/* 头像按钮样式 */
.owner-avatar {
    width: 70rpx;
    height: 70rpx;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
    transition: transform 0.2s ease;
}

.owner-avatar:active {
    transform: scale(0.95);
}

.avatar-icon {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* 空数据提示 */
.no-data {
    text-align: center;
    color: #999;
    padding: 30rpx;
    font-size: 28rpx;
}
/* 摊位状态模块 */
.stall-info {
    padding: 20rpx;
    background-color: #fff;
    border-radius: 10rpx;
    margin-bottom: 20rpx;
    text-align: center;
    box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.stall-name {
    font-size: 28rpx;
    font-weight: bold;
    margin-bottom: 10rpx;
    color: #333;
}

.stall-status {
    padding: 8rpx 20rpx;
    border-radius: 20rpx;
    font-size: 24rpx;
    transition: all 0.3s ease;
  }
  
  .stall-status.open {
    background: #e8f5e9;
    color: #4caf50;
  }
  
  .stall-status.closed {
    background: #f5f5f5;
    color: #999;
  }

/** 轮播图容器 **/
.swiper-container {
    width: 100%;
    height: 300rpx;
    margin-bottom: 30rpx;
    border-radius: 10rpx;
    overflow: hidden;
}

.swiper-image {
    width: 100%;
    height: 300rpx;
}

/** 标题 **/
.section-title {
    font-size: 32rpx;
    font-weight: bold;
    margin-bottom: 20rpx;
    color: #333;
}


/* 空列表样式 */
.empty-list {
    padding: 60rpx 0;
    text-align: center;
    background: #fff;
    border-radius: 12rpx;
    margin: 20rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}

.empty-icon {
    width: 600rpx;
    height: 300rpx;
    margin-bottom: 30rpx;
    opacity: 0.7;
}


/** 摊位卡片 **/
.stall-card {
    display: flex;
    /* align-items: center; */
    background-color: #ffffff;
    border-radius: 10rpx;
    margin-bottom: 20rpx;
    padding: 20rpx;
    box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}

/** 打烊时整张卡片半透明显示 **/
.stall-card.closed {
    opacity: 0.5;
}

/** 头像区域 **/
.avatar-container {
    position: relative;
    margin-right: 5rpx;
}

.avatar {
    width: 200rpx;
    height: 200rpx;
    /* border-radius: 50%; */
    background-color: #eee;
}

/** 休息中文案 **/
.resting {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: #f44;
    font-size: 33rpx;
    font-weight: bold;
}

/** 摊位文字信息 **/
.stall-info {
    flex: 1;
}

.stall-name {
    font-size: 28rpx;
    font-weight: bold;
    margin-bottom: 8rpx;
    color: #000;
}

.stall-desc {
    font-size: 24rpx;
    color: #666;
}

/* 切换按钮样式 */
wx-button.toggle-btn {
    position: fixed;
    right: 20rpx;
    bottom: 40rpx;
    width: 180rpx;
    height: 60rpx;
    background-color: #ff4d4f;
    color: #fff;
    border-radius: 30rpx;
    font-size: 24rpx;
    box-shadow: 0 4rpx 12rpx rgba(255, 153, 0, 0.3);
    display: flex;
    justify-content: center;
    align-items: center;
    transition: all 0.2s ease;
}

wx-button.toggle-btn.open {
    background: #52c41a;
  }

wx-button.toggle-btn:active {
    transform: translateY(2rpx);
    box-shadow: 0 2rpx 6rpx rgba(255, 153, 0, 0.2);
}