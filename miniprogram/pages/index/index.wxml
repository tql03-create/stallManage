<view class="container">

<!-- 顶部搜索栏 -->
<view class="header">
  <view class="search-bar">
    <!-- <image class="search-icon" src="/assets/icon_search.png" mode="aspectFit" /> -->
    <icon type="search" class="search-icon"/>
    <input 
      class="search-input" 
      placeholder="搜索关键词（如：饭）" 
      confirm-type="search"
      bindconfirm="handleSearch"
      bindinput="handleSearch"
    />
  </view>
  <!-- 右侧头像按钮，用于摊主注册或登录 -->
 <view class="owner-avatar" bindtap="onOwnerAvatarTap">
  <image 
    class="avatar-icon" 
    src="{{userInfo && userInfo.avatarUrl ? userInfo.avatarUrl : '../../images/icons/vendor.png'}}" 
    mode="aspectFill" 
  />
</view>
</view>

<!-- 出摊与否状态模块 -->
<!-- 出摊与否状态模块 -->
<!-- 出摊与否状态模块 -->
<view wx:if="{{userInfo && myStall}}" class="stall-info">
  <text class="stall-name">{{myStall.stallName}}</text>
  <text class="stall-status">{{ !myStall.isOpen ? '休息中' : '出摊中' }}</text>
</view>


<!-- 轮播图 -->
<view class="swiper-container">
  <swiper circular="{{true}}"  indicator-dots="{{true}}" autoplay="{{true}}" interval="{{3000}}" duration="{{500}}">
    <block wx:for="{{carouselImages}}" wx:key="index">
      <swiper-item>
        <image class="swiper-image" src="{{item}}" mode="aspectFill"></image>
      </swiper-item>
    </block>
  </swiper>
</view>

<!-- 出摊中的摊位标题 -->
<view class="section-title">美食摊位</view>

<!-- 摊位卡片列表 -->
<!-- 摊位卡片列表 -->
<!-- 摊位卡片列表 -->
<view class="stall-list">
  
  
    <block wx:for="{{ filteredStalls }}" wx:key="_id">
      <view class="stall-card {{!item.isOpen ? 'closed' : ''}}" data-id="{{item._id}}">
        <view class="avatar-container">
          <image class="avatar" src="{{item.stallImage}}" mode="aspectFill"></image>
          <view class="resting" wx:if="{{!item.isOpen}}">休息中</view>
        </view>
        <view class="stall-info">
          <view class="stall-name">{{item.stallName}}</view>
          <view class="stall-desc">{{item.stallDesc}}</view>
        </view>
      </view>
    </block>
  
</view>

<!-- 右下角 出摊/收摊 切换按钮 -->
<button wx:if="{{userInfo}}" class="toggle-btn" bindtap="onToggleStallStatus">
  {{toggleStallText}}
</button>
</view>
